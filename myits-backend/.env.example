# Copy this file to .env and fill actual values
# Example (PowerShell): Copy-Item .env.example .env

# Keep true in local dev if you want OTP visible in API response.
# Set false for production.
OTP_DEBUG_RETURN_OTP_FOR_TESTING=false

# Use TWILIO to send OTP on real mobile numbers.
# Keep MOCK only for local testing without SMS.
OTP_SMS_PROVIDER=TWILIO

# Twilio credentials
OTP_SMS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OTP_SMS_TWILIO_AUTH_TOKEN=your_twilio_auth_token
OTP_SMS_TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# OTP policy
OTP_VALIDITY_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_MS=30000
