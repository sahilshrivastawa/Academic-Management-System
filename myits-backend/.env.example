# Copy this file to .env and fill actual values
# Example (PowerShell): Copy-Item .env.example .env

# Database (set these for cloud Postgres/MySQL, otherwise H2 defaults from application.properties are used)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-key-for-myits-backend-auth
JWT_EXPIRATION_MS=86400000

# Keep true in local dev if you want OTP visible in API response.
# Set false for production.
OTP_DEBUG_RETURN_OTP_FOR_TESTING=false

# Use TWILIO to send OTP on real mobile numbers.
# Keep MOCK only for local testing without SMS.
OTP_SMS_PROVIDER=TWILIO

# Twilio credentials
OTP_SMS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OTP_SMS_TWILIO_AUTH_TOKEN=your_twilio_auth_token
OTP_SMS_TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# OTP policy
OTP_VALIDITY_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_MS=30000

# External AI services (optional)
AI_ATTENDANCE_SERVICE_URL=http://localhost:8001/predict-attendance
AI_CHATBOT_SERVICE_URL=http://localhost:8001/chatbot/ask
AI_PERFORMANCE_SERVICE_URL=http://localhost:8001/analyze-performance
